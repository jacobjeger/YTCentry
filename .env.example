# ── Database (Railway Postgres) ───────────────────────────────────────────────
# Used by: dashboard, ingest, prisma CLI (packages/core)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# ── Session / auth (dashboard) ────────────────────────────────────────────────
# 32+ random bytes, base64. Generate: openssl rand -base64 48
SESSION_SECRET="change-me"

# ── Cloud → agent queue auth (dashboard + agent share this) ───────────────────
AGENT_BEARER_TOKEN="change-me-long-random"

# ── Object storage: Railway Bucket — S3-compatible (dashboard + ingest) ───────
# `railway bucket credentials --bucket ytc-faces --json` prints these. Note the
# real S3 bucket name differs from the display name. Virtual-host style.
S3_ENDPOINT="https://t3.storageapi.dev"
S3_REGION="auto"
S3_BUCKET="ytc-faces-xxxxxxxx"
S3_ACCESS_KEY="tid_..."
S3_SECRET_KEY="tsec_..."
# S3_FORCE_PATH_STYLE="true"   # only for path-style stores (self-hosted MinIO)

# ── Gmail ingestion (ingest worker only) ──────────────────────────────────────
GMAIL_USER="your-enrollment-mailbox@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"   # 16-char app password, 2FA required
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"

# ── On-site agent ONLY (lives in the building, never in the cloud) ────────────
# AKUVOX_BASE_URL="http://10.0.0.215"
# AKUVOX_API_USER="admin"
# AKUVOX_API_PASSWORD="rotate-off-the-setup-value"   # HTTP API pass, not web login
# CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET      # Cloudflare tunnel headers
# DASHBOARD_URL="https://ytc-dashboard.up.railway.app"
# AGENT_BEARER_TOKEN="same-as-dashboard"
# AGENT_POLL_MS="3000"

# ── Door-snapshot enrollment (pusher; denied scans → Review Queue) ────────────
# Uses the /web session API (separate WEB login password, not the HTTP API one).
# DOOR_SNAPSHOTS="true"
# AKUVOX_WEB_PASSWORD="the-web-login-password"
# AKUVOX_WEB_USER="admin"
# DOOR_POLL_MS="60000"
# ACCESS_LOG_STATUS="3"   # device log filter; tune to the value that shows denials
